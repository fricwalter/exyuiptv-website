---
import BaseLayout from '../../layouts/BaseLayout.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import { blogPosts } from '../../data/blogPosts';

export function getStaticPaths() {
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props;

const categoryIcons: Record<string, string> = {
  'Instalacija': '🔧',
  'Uredaji': '📦',
  'Vodic': '📖',
  'Savjeti': '💡',
  'Pravno': '⚖️',
  'Kanali': '📺',
  'Dijaspora': '🌍',
};
---

<BaseLayout
  title={`${post.title} | EXYU IPTV Blog`}
  description={post.excerpt}
  canonicalUrl={`https://exyuiptv.org/blog/${post.slug}`}
>
  <div class="pt-20 min-h-screen" style="background: rgb(28 25 23);">

    <!-- Hero Banner -->
    <div class="w-full h-56 bg-gradient-to-br from-blue-700 via-purple-700 to-blue-900 relative overflow-hidden flex items-center justify-center">
      {post.image ? (
        <img
          src={post.image}
          alt={post.title}
          width="1200"
          height="224"
          class="absolute inset-0 w-full h-full object-cover opacity-70"
        />
      ) : (
        <span class="text-8xl relative z-10">{categoryIcons[post.category] ?? '📺'}</span>
      )}
      {post.image && (
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/20 to-transparent z-10" />
      )}
    </div>

    <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

      <!-- Breadcrumb -->
      <nav class="flex items-center gap-2 text-sm text-gray-500 mb-8">
        <a href="/" class="hover:text-blue-400 transition-colors">Početna</a>
        <span>/</span>
        <a href="/blog" class="hover:text-blue-400 transition-colors">Blog</a>
        <span>/</span>
        <span class="text-gray-300 truncate">{post.title}</span>
      </nav>

      <!-- Header -->
      <header class="mb-10">
        <div class="flex flex-wrap items-center gap-3 mb-4">
          <span class="px-3 py-1 bg-blue-900/60 text-blue-300 text-sm font-semibold rounded-full">
            {post.category}
          </span>
          <time datetime={post.date} class="text-gray-500 text-sm">
            {new Date(post.date).toLocaleDateString('de-DE')}
          </time>
          <span class="text-gray-600">·</span>
          <span class="text-gray-500 text-sm">{post.readTime} čitanja</span>
        </div>
        <h1 class="text-3xl sm:text-4xl font-bold text-white leading-tight">
          {post.title}
        </h1>
      </header>

      <!-- Content -->
      <div class="prose-custom text-gray-300 space-y-6 leading-relaxed">
        {post.htmlContent ? (
          <Fragment set:html={post.htmlContent} />
        ) : (
          <>
            <p class="text-xl text-gray-200 font-medium border-l-4 border-blue-500 pl-4">
              {post.excerpt}
            </p>

            <h2 class="text-2xl font-bold text-white mt-8">Šta vam je potrebno?</h2>
            <p>Prije nego što počnete s instalacijom, provjerite da imate:</p>
            <ul class="space-y-2">
              {['Aktivan EXYU IPTV nalog', 'Stabilnu internet konekciju (min. 30 Mbps)', 'Podržanu aplikaciju na uređaju'].map(item => (
                <li class="flex items-start gap-3">
                  <span class="mt-1 w-5 h-5 flex-shrink-0 bg-gradient-to-r from-blue-600 to-purple-600 rounded-full flex items-center justify-center">
                    <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                    </svg>
                  </span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>

            <h2 class="text-2xl font-bold text-white mt-8">Korak 1: Preuzimanje aplikacije</h2>
            <p>Otvorite trgovinu aplikacija na svom uređaju i potražite preporučenu IPTV aplikaciju (IPTV Smarters Pro, TiviMate, ili GSE IPTV).</p>

            <h2 class="text-2xl font-bold text-white mt-8">Korak 2: Instalacija</h2>
            <p>Pokrenite instalaciju i pričekajte da se aplikacija u potpunosti instalira na vaš uređaj. Proces traje manje od 2 minute.</p>

            <h2 class="text-2xl font-bold text-white mt-8">Korak 3: Konfiguracija</h2>
            <p>Unesite pristupne podatke koje ste dobili nakon narudžbe (M3U URL ili Xtream Codes) i testirajte reprodukciju kanala.</p>

            <h2 class="text-2xl font-bold text-white mt-8">Zaključak</h2>
            <p class="text-gray-200">{post.content}</p>
          </>
        )}

        <!-- CTA Box -->
        <div class="mt-10 p-6 bg-gradient-to-r from-blue-900/50 to-purple-900/50 rounded-2xl border border-blue-700/40">
          <p class="font-bold text-white text-lg mb-2">🎁 Probajte besplatno 24 sata!</p>
          <p class="text-gray-300 mb-4">Aktivirajte test nalog i uvjerite se sami u kvalitetu naše usluge prije nego što se pretplatite.</p>
          <a
            href="/narudzba"
            class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-blue-600 to-purple-600 text-white font-semibold rounded-xl hover:shadow-lg hover:-translate-y-0.5 transition-all"
          >
            Kontaktirajte nas →
          </a>
        </div>
      </div>

      <!-- Share -->
      <div class="mt-12 pt-8 border-t border-stone-700">
        <p class="font-semibold text-white mb-4">Podijelite ovaj članak:</p>
        <div class="flex gap-4">
          <a
            href={`https://wa.me/4915251741280?text=${encodeURIComponent(post.title + ' - https://exyuiptv.org/blog/' + post.slug)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="px-5 py-2 bg-green-600 text-white rounded-xl hover:bg-green-500 transition-colors font-semibold text-sm"
          >
            💬 WhatsApp
          </a>
          <a
            href={`mailto:?subject=${encodeURIComponent(post.title)}&body=${encodeURIComponent(post.excerpt + '\n\nhttps://exyuiptv.org/blog/' + post.slug)}`}
            class="px-5 py-2 bg-blue-700 text-white rounded-xl hover:bg-blue-600 transition-colors font-semibold text-sm"
          >
            ✉️ Email
          </a>
        </div>
      </div>

      <!-- Related Posts -->
      <RelatedPosts currentSlug={post.slug} currentCategory={post.category} />

      <!-- Back -->
      <div class="mt-10">
        <a href="/blog" class="inline-flex items-center gap-2 text-blue-400 font-semibold hover:gap-3 transition-all">
          ← Nazad na blog
        </a>
      </div>

    </article>
    <div class="pb-16"></div>
  </div>
</BaseLayout>
