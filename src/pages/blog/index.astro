---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { blogPosts } from '../../data/blogPosts';

const categoryIcons: Record<string, string> = {
  'Instalacija': '🔧',
  'Uredaji': '📦',
  'Vodic': '📖',
  'Savjeti': '💡',
  'Pravno': '⚖️',
  'Kanali': '📺',
  'Dijaspora': '🌍',
};

const posts = [...blogPosts].sort(
  (a, b) => new Date(b.date).getTime() - new Date(a.date).getTime()
);
---

<BaseLayout
  title="IPTV Blog | EXYU IPTV - Vodiči, Savjeti i Novosti"
  description="Pročitajte najnovije vodiče za instalaciju IPTV-a, savjete za stabilniji streaming i novosti iz svijeta EXYU televizije."
  canonicalUrl="https://exyuiptv.org/blog"
>
  <div class="pt-20 pb-20 min-h-screen" style="background: rgb(28 25 23);">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">

      <!-- Header -->
      <div class="text-center mb-16">
        <h1 class="text-4xl sm:text-5xl font-bold text-white mb-4">
          IPTV <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-purple-400">Blog</span>
        </h1>
        <p class="text-lg text-gray-300 max-w-2xl mx-auto">
          Vodiči za instalaciju, savjeti za stabilan stream i sve što trebate znati o EXYU IPTV-u.
        </p>
      </div>

      <!-- Grid -->
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {posts.map((post) => (
          <article class="group bg-stone-800 rounded-2xl overflow-hidden border border-stone-700 hover:border-blue-500 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
            <div class="h-48 bg-gradient-to-br from-blue-600 to-purple-700 flex items-center justify-center">
              <span class="text-7xl">{categoryIcons[post.category] ?? '📺'}</span>
            </div>
            <div class="p-6">
              <div class="flex items-center gap-3 mb-3">
                <span class="px-3 py-1 bg-blue-900/60 text-blue-300 text-xs font-semibold rounded-full">
                  {post.category}
                </span>
                <time datetime={post.date} class="text-gray-500 text-sm">
                  {new Date(post.date).toLocaleDateString('de-DE')}
                </time>
                <span class="text-gray-600 text-sm">· {post.readTime}</span>
              </div>
              <h2 class="text-lg font-bold text-white mb-3 group-hover:text-blue-400 transition-colors line-clamp-2">
                <a href={`/blog/${post.slug}`}>{post.title}</a>
              </h2>
              <p class="text-gray-400 text-sm mb-4 line-clamp-3">{post.excerpt}</p>
              <a
                href={`/blog/${post.slug}`}
                class="inline-flex items-center gap-1 text-blue-400 font-semibold hover:gap-2 transition-all text-sm"
              >
                Pročitaj više →
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>
