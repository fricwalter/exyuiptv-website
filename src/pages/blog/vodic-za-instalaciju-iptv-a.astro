---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Vodič za instalaciju IPTV-a - EXYU IPTV" description="Jednostavne upute za instalaciju IPTV-a na Smart TV, Android, Fire TV i druge uređaje.">
  <section class="section bg-white">
    <div class="container-custom">
      <div class="max-w-3xl mx-auto">
        <a href="/blog" class="text-blue-600 hover:text-blue-700 mb-6 inline-flex items-center gap-1"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>Natrag na blog</a>
        <span class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-sm font-medium">Upute</span>
        <h1 class="text-3xl md:text-4xl font-bold text-slate-800 mt-4 mb-6">Kompletan vodič za instalaciju IPTV-a</h1>
        <div class="flex items-center gap-4 text-slate-500 mb-8"><span>23.02.2025</span><span>•</span><span>8 min čitanja</span></div>
        <div class="prose prose-lg max-w-none">
          <p class="text-xl text-slate-600 mb-8">Saznajte kako jednostavno instalirati IPTV na vaš uređaj korak po korak.</p>
          <h2 class="text-2xl font-bold text-slate-800 mt-12 mb-4">Android box / Fire TV</h2>
          <ol class="list-decimal list-inside space-y-2 text-slate-600 mb-8">
            <li>Preuzmite IPTV aplikaciju</li>
            <li>Unesite podatke za prijavu</li>
            <li>Uživajte u gledanju</li>
          </ol>
          <h2 class="text-2xl font-bold text-slate-800 mt-12 mb-4">Smart TV</h2>
          <ol class="list-decimal list-inside space-y-2 text-slate-600 mb-8">
            <li>Otvorite trgovinu aplikacija</li>
            <li>Instalirajte IPTV aplikaciju</li>
            <li>Unesite MAC adresu i podatke</li>
          </ol>
          <div class="bg-blue-50 rounded-2xl p-8 mt-8">
            <a href="/kontakt" class="btn btn-primary">Trebate pomoć?</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
