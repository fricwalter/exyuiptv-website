---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Lista kanala - EXYU IPTV" description="Pregledajte kompletnu listu TV kanala koje nudimo - preko 25.000 kanala u HD i 4K kvalitetu.">
  <section class="section bg-white">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-4xl md:text-5xl font-bold text-slate-800 mb-4">
          Lista kanala
        </h1>
        <p class="text-xl text-slate-600 mb-12">
          Pregledajte kompletnu ponudu naših TV kanala
        </p>

        <div class="bg-blue-50 rounded-2xl p-8 mb-12">
          <h2 class="text-2xl font-bold text-slate-800 mb-4">Preko 25.000 kanala</h2>
          <p class="text-slate-600 mb-6">
            Nudimo jednu od najvećih kolekcija TV kanala na tržištu, uključujući sve balkanske programe, međunarodne kanale, filmove, serije, sport i još mnogo toga.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <!-- Bosnian Channels -->
          <div class="card">
            <h3 class="text-xl font-bold text-slate-800 mb-4 flex items-center gap-2">
              <span class="text-2xl">🇧🇦</span> Bosna i Hercegovina
            </h3>
            <ul class="space-y-2 text-slate-600">
              <li>BHT 1</li>
              <li>FTV</li>
              <li>RTRS</li>
              <li>Hayat TV</li>
              <li>Hayat Plus</li>
              <li>OBN</li>
              <li>TVSA</li>
              <li>N1 Bosna</li>
            </ul>
          </div>

          <!-- Croatian Channels -->
          <div class="card">
            <h3 class="text-xl font-bold text-slate-800 mb-4 flex items-center gap-2">
              <span class="text-2xl">🇭🇷</span> Hrvatska
            </h3>
            <ul class="space-y-2 text-slate-600">
              <li>HRT 1</li>
              <li>HRT 2</li>
              <li>HRT 3</li>
              <li>HRT 4</li>
              <li>Nova TV</li>
              <li>RTL</li>
              <li>Playboy</li>
              <li>Sport Klub</li>
            </ul>
          </div>

          <!-- Serbian Channels -->
          <div class="card">
            <h3 class="text-xl font-bold text-slate-800 mb-4 flex items-center gap-2">
              <span class="text-2xl">🇷🇸</span> Srbija
            </h3>
            <ul class="space-y-2 text-slate-600">
              <li>RTS 1</li>
              <li>RTS 2</li>
              <li>RTS 3</li>
              <li>Pink</li>
              <li>Pink Plus</li>
              <li>B92</li>
              <li>Prva</li>
              <li>N1 Srbija</li>
            </ul>
          </div>

          <!-- Slovenian Channels -->
          <div class="card">
            <h3 class="text-xl font-bold text-slate-800 mb-4 flex items-center gap-2">
              <span class="text-2xl">🇸🇮</span> Slovenija
            </h3>
            <ul class="space-y-2 text-slate-600">
              <li>RTV SLO 1</li>
              <li>RTV SLO 2</li>
              <li>Pop TV</li>
              <li>Kanal A</li>
              <li>Planet TV</li>
              <li>SLO 1</li>
            </ul>
          </div>
        </div>

        <div class="mt-12">
          <h2 class="text-2xl font-bold text-slate-800 mb-6">Dodatne kategorije</h2>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            <div class="bg-slate-50 rounded-xl p-4 text-center">
              <div class="text-3xl mb-2">🎬</div>
              <div class="font-semibold text-slate-800">Filmovi</div>
            </div>
            <div class="bg-slate-50 rounded-xl p-4 text-center">
              <div class="text-3xl mb-2">📺</div>
              <div class="font-semibold text-slate-800">Serije</div>
            </div>
            <div class="bg-slate-50 rounded-xl p-4 text-center">
              <div class="text-3xl mb-2">⚽</div>
              <div class="font-semibold text-slate-800">Sport</div>
            </div>
            <div class="bg-slate-50 rounded-xl p-4 text-center">
              <div class="text-3xl mb-2">🎵</div>
              <div class="font-semibold text-slate-800">Muzika</div>
            </div>
            <div class="bg-slate-50 rounded-xl p-4 text-center">
              <div class="text-3xl mb-2">🧒</div>
              <div class="font-semibold text-slate-800">Dječiji</div>
            </div>
            <div class="bg-slate-50 rounded-xl p-4 text-center">
              <div class="text-3xl mb-2">📰</div>
              <div class="font-semibold text-slate-800">Vijesti</div>
            </div>
            <div class="bg-slate-50 rounded-xl p-4 text-center">
              <div class="text-3xl mb-2">🎥</div>
              <div class="font-semibold text-slate-800">Dokumentarci</div>
            </div>
            <div class="bg-slate-50 rounded-xl p-4 text-center">
              <div class="text-3xl mb-2">🔞</div>
              <div class="font-semibold text-slate-800">Odrasli</div>
            </div>
          </div>
        </div>

        <div class="mt-12 text-center">
          <p class="text-slate-600 mb-6">
            Zanima vas kompletna lista? Kontaktirajte nas za detaljni spisak svih kanala.
          </p>
          <a href="/narudzba" class="btn btn-primary">
            Zatraži kompletnu listu
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
