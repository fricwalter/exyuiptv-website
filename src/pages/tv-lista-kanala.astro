---
import BaseLayout from '../layouts/BaseLayout.astro';

const countries = [
  {
    flag: "🇧🇦", name: "Bosna i Hercegovina", color: "from-yellow-500/20 to-blue-600/20", border: "border-yellow-500/30",
    channels: ["BHT 1", "FTV", "RTRS", "Hayat TV", "Hayat Plus", "OBN", "TVSA", "N1 BiH", "Face TV", "Al Jazeera Balkans", "Federalna TV", "BN TV", "NTV Hayat", "TV1", "Kanal S"]
  },
  {
    flag: "🇷🇸", name: "Srbija", color: "from-red-600/20 to-blue-600/20", border: "border-red-500/30",
    channels: ["RTS 1", "RTS 2", "RTS 3", "Pink", "Pink Plus", "Pink Film", "B92", "Prva", "N1 Srbija", "Nova S", "Happy TV", "O2 TV", "Arena Sport 1", "Arena Sport 2", "Kurir TV"]
  },
  {
    flag: "🇭🇷", name: "Hrvatska", color: "from-red-600/20 to-blue-600/20", border: "border-red-400/30",
    channels: ["HRT 1", "HRT 2", "HRT 3", "HRT 4", "Nova TV", "RTL", "RTL 2", "Sport Klub", "24sata TV", "Doma TV", "CMC", "HTV", "Z1 TV", "Otvoreni radio TV", "MaxSport"]
  },
  {
    flag: "🇸🇮", name: "Slovenija", color: "from-blue-600/20 to-red-600/20", border: "border-blue-500/30",
    channels: ["SLO 1", "SLO 2", "SLO 3", "Pop TV", "Kanal A", "Planet TV", "TV3", "Koper Capodistria", "TV Slovenija 1", "RTV SLO 1", "RTV SLO 2", "Brio", "Siol TV", "TV Pika", "Fokus TV"]
  },
  {
    flag: "🇲🇰", name: "Makedonija", color: "from-red-600/20 to-yellow-500/20", border: "border-yellow-400/30",
    channels: ["MRT 1", "MRT 2", "MRT 3", "Sitel", "Alsat-M", "Kanal 5", "Alfa TV", "TV Telma", "24Vesti", "MTV 1", "TV Tera", "Gran", "Nasha TV", "Era TV", "Sigma+"]
  },
  {
    flag: "🇲🇪", name: "Crna Gora", color: "from-red-600/20 to-yellow-500/20", border: "border-red-400/30",
    channels: ["RTCG 1", "RTCG 2", "Vijesti TV", "TV Prva CG", "Pink M", "Atlas TV", "In TV", "TV Budva", "Teuta TV", "RTV Bar", "TV Nikšić", "D&D TV", "NTV", "TV CDM", "MBC"]
  },
  {
    flag: "🇦🇱", name: "Albanija", color: "from-red-700/20 to-red-900/20", border: "border-red-600/30",
    channels: ["TVSH", "Top Channel", "Vizion Plus", "Klan", "A1 Report", "News 24", "Ora News", "ABC News Albania", "Euronews Albania", "Tring Sport", "Tring HD", "RTV Ora", "Agon Channel", "SuperStar TV", "Gold TV"]
  },
  {
    flag: "🇩🇪", name: "Njemacka / Diaspora", color: "from-gray-700/20 to-yellow-500/20", border: "border-yellow-400/30",
    channels: ["ARD", "ZDF", "RTL", "Sat.1", "ProSieben", "VOX", "kabel eins", "RTL II", "Tele 5", "3sat", "ARTE", "WDR", "Bayern TV", "DMAX", "Nickelodeon DE"]
  },
];

const genres = [
  { icon: "⚽", name: "Sport", count: "2.500+", desc: "Football, Basketball, Tennis, F1, MMA...", color: "from-green-600/20 to-emerald-600/20", border: "border-green-500/30", text: "text-green-400" },
  { icon: "🎬", name: "Filmovi", count: "8.000+", desc: "Action, Drama, Comedy, Thriller, Horror...", color: "from-blue-600/20 to-cyan-600/20", border: "border-blue-500/30", text: "text-blue-400" },
  { icon: "📺", name: "Serije", count: "5.000+", desc: "Netflix Originali, HBO, Prime Video sadržaj...", color: "from-purple-600/20 to-violet-600/20", border: "border-purple-500/30", text: "text-purple-400" },
  { icon: "📰", name: "Vijesti", count: "300+", desc: "CNN, BBC, Al Jazeera, Sky News, BFMTV...", color: "from-orange-600/20 to-red-600/20", border: "border-orange-500/30", text: "text-orange-400" },
  { icon: "🧒", name: "Dječiji", count: "400+", desc: "Cartoon Network, Disney, Nickelodeon...", color: "from-yellow-500/20 to-orange-500/20", border: "border-yellow-500/30", text: "text-yellow-400" },
  { icon: "🎵", name: "Muzika", count: "200+", desc: "MTV, VH1, CMC, Music Box, Grand...", color: "from-pink-600/20 to-rose-600/20", border: "border-pink-500/30", text: "text-pink-400" },
  { icon: "📡", name: "Dokumentarci", count: "500+", desc: "National Geographic, Discovery, History...", color: "from-teal-600/20 to-cyan-600/20", border: "border-teal-500/30", text: "text-teal-400" },
  { icon: "🌍", name: "Internacionalni", count: "3.000+", desc: "Turski, Arapski, Indijski, Latinski...", color: "from-indigo-600/20 to-blue-600/20", border: "border-indigo-500/30", text: "text-indigo-400" },
];
---

<BaseLayout
  title="Lista TV Kanala | 25.000+ EXYU IPTV Kanala"
  description="Kompletna lista EXYU IPTV kanala — Bosna, Srbija, Hrvatska, Slovenija, Makedonija, Crna Gora i mnogo više. HD & 4K kvalitet."
>

  <!-- Hero -->
  <section class="relative pt-32 pb-20 overflow-hidden" style="background: linear-gradient(135deg, #1e3a5f 0%, #1c1917 60%);">
    <div class="absolute inset-0 opacity-10"
      style="background-image: radial-gradient(circle at 20% 50%, #3b82f6 0%, transparent 50%), radial-gradient(circle at 80% 20%, #7c3aed 0%, transparent 50%);">
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-blue-500/20 border border-blue-500/40 text-blue-300 rounded-full text-sm font-semibold mb-6">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        Ažurirano dnevno
      </div>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6">
        Lista <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-purple-400">TV Kanala</span>
      </h1>
      <p class="text-xl text-gray-300 max-w-2xl mx-auto mb-10">
        Više od 25.000 kanala iz cijelog svijeta u HD i 4K kvalitetu — sve balkanske zemlje, sport, filmovi, serije i više.
      </p>

      <!-- Stats -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 max-w-3xl mx-auto">
        {[
          { num: "25.000+", label: "Live kanala" },
          { num: "8.000+", label: "Filmova VOD" },
          { num: "5.000+", label: "Serija VOD" },
          { num: "4K / HD", label: "Kvalitet slike" },
        ].map(s => (
          <div class="bg-white/10 backdrop-blur border border-white/20 rounded-2xl px-4 py-4">
            <div class="text-2xl font-extrabold text-white">{s.num}</div>
            <div class="text-xs text-gray-400 mt-1">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Genre Categories -->
  <section class="py-16 bg-stone-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-white mb-3">Kategorije sadržaja</h2>
        <p class="text-gray-400">Sve što možete gledati na jednom mjestu</p>
      </div>

      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
        {genres.map(g => (
          <div class={`bg-gradient-to-br ${g.color} border ${g.border} rounded-2xl p-5 hover:scale-105 transition-transform duration-200`}>
            <div class="text-3xl mb-3">{g.icon}</div>
            <div class="font-bold text-white text-lg">{g.name}</div>
            <div class={`text-sm font-semibold ${g.text} mb-1`}>{g.count}</div>
            <div class="text-xs text-gray-500 leading-tight">{g.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Country Channels -->
  <section class="py-16 bg-stone-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-white mb-3">Kanali po zemlji</h2>
        <p class="text-gray-400">Pregled glavnih kanala po regijama — ovo je samo mali dio ponude</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {countries.map(c => (
          <div class={`bg-gradient-to-br ${c.color} border ${c.border} bg-stone-800/80 rounded-2xl overflow-hidden hover:shadow-xl hover:shadow-blue-900/20 transition-shadow duration-300`}>
            <div class="px-5 py-4 border-b border-stone-700/60 flex items-center gap-3">
              <span class="text-3xl">{c.flag}</span>
              <h3 class="font-bold text-white text-sm leading-tight">{c.name}</h3>
            </div>
            <div class="px-5 py-4">
              <ul class="space-y-1.5">
                {c.channels.slice(0, 8).map(ch => (
                  <li class="flex items-center gap-2 text-gray-300 text-sm">
                    <span class="w-1.5 h-1.5 rounded-full bg-blue-500 flex-shrink-0"></span>
                    {ch}
                  </li>
                ))}
              </ul>
              {c.channels.length > 8 && (
                <div class="mt-3 text-xs text-blue-400 font-semibold">
                  + {c.channels.length - 8} više kanala...
                </div>
              )}
            </div>
          </div>
        ))}
      </div>

      <!-- More countries note -->
      <div class="mt-10 bg-stone-800 border border-stone-700 rounded-2xl p-6 text-center">
        <p class="text-gray-400 text-sm">
          Prikazano je samo <strong class="text-white">8 od 25.000+ kanala</strong> po zemlji.
          Dostupni su i kanali iz Turske, Albanije, Kosova, Njemačke, Austrije, Švicarske, Skandinavije, UK, SAD, Kanade i još 50+ zemalja.
        </p>
      </div>
    </div>
  </section>

  <!-- Sport Special Section -->
  <section class="py-16 bg-stone-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-gradient-to-br from-green-600/15 to-blue-600/15 border border-green-500/25 rounded-3xl p-8 md:p-12">
        <div class="grid md:grid-cols-2 gap-10 items-center">
          <div>
            <div class="inline-flex items-center gap-2 px-3 py-1 bg-green-500/20 border border-green-500/40 text-green-400 rounded-full text-xs font-bold mb-5">
              ⚽ SPORT PAKETI
            </div>
            <h2 class="text-3xl font-bold text-white mb-4">Sav sport na jednom mjestu</h2>
            <p class="text-gray-300 mb-6">Pratite sve važne sportske događaje — fudbal, košarku, tenis, F1, MMA i još mnogo toga, sve u HD i 4K kvalitetu.</p>
            <div class="flex flex-wrap gap-3">
              {["Arena Sport 1-6", "Sport Klub 1-6", "Eurosport 1-2", "DAZN", "Sky Sports", "BT Sport", "beIN Sports", "Premier Sports"].map(s => (
                <span class="px-3 py-1.5 bg-green-500/15 border border-green-500/30 text-green-300 rounded-lg text-xs font-semibold">{s}</span>
              ))}
            </div>
          </div>
          <div class="grid grid-cols-2 gap-4">
            {[
              { icon: "⚽", sport: "Fudbal", leagues: "Liga prvaka, Premier liga, Bundesliga, La Liga, Serie A" },
              { icon: "🏀", sport: "Košarka", leagues: "NBA, Euroliga, ABA liga, FIBA" },
              { icon: "🎾", sport: "Tenis", leagues: "Wimbledon, Roland Garros, US Open, Australian Open" },
              { icon: "🏎️", sport: "Formula 1", leagues: "Sve trke uživo, kvalifikacije i treninzi" },
            ].map(s => (
              <div class="bg-stone-800/80 border border-stone-700 rounded-xl p-4">
                <div class="text-2xl mb-2">{s.icon}</div>
                <div class="font-bold text-white text-sm mb-1">{s.sport}</div>
                <div class="text-xs text-gray-500 leading-tight">{s.leagues}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- VOD Section -->
  <section class="py-16 bg-stone-950">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-white mb-3">Video na zahtjev (VOD)</h2>
        <p class="text-gray-400">13.000+ filmova i serija dostupnih kada vi hoćete</p>
      </div>
      <div class="grid sm:grid-cols-3 gap-6">
        <div class="bg-stone-800 border border-stone-700 rounded-2xl p-7 text-center hover:border-blue-500/50 transition-colors">
          <div class="text-5xl mb-4">🎬</div>
          <div class="text-3xl font-extrabold text-white mb-1">8.000+</div>
          <div class="text-blue-400 font-semibold mb-3">Filmova</div>
          <p class="text-gray-500 text-sm">Najnoviji naslovi, klasici, akcija, drama, komedija — sve u HD kvalitetu s titlovima.</p>
        </div>
        <div class="bg-stone-800 border border-stone-700 rounded-2xl p-7 text-center hover:border-purple-500/50 transition-colors">
          <div class="text-5xl mb-4">📺</div>
          <div class="text-3xl font-extrabold text-white mb-1">5.000+</div>
          <div class="text-purple-400 font-semibold mb-3">Serija</div>
          <p class="text-gray-500 text-sm">Kompletne sezone popularnih serija — Netflix, HBO, Prime Video i balkanske produkcije.</p>
        </div>
        <div class="bg-stone-800 border border-stone-700 rounded-2xl p-7 text-center hover:border-green-500/50 transition-colors">
          <div class="text-5xl mb-4">📼</div>
          <div class="text-3xl font-extrabold text-white mb-1">7 dana</div>
          <div class="text-green-400 font-semibold mb-3">Catch-up TV</div>
          <p class="text-gray-500 text-sm">Propustili ste emisiju? Gledajte sadržaj iz prethodnih 7 dana na većini kanala.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 bg-stone-900">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="bg-gradient-to-br from-blue-600/20 to-purple-600/20 border border-blue-500/30 rounded-3xl p-10 text-center">
        <div class="text-4xl mb-4">🎬</div>
        <h3 class="text-2xl font-bold text-white mb-3">Isprobajte 24h besplatno</h3>
        <p class="text-gray-300 mb-8 max-w-lg mx-auto">
          Niste sigurni koji paket odabrati? Pošaljite nam poruku i dobijete besplatni test pristup sa svim kanalima i VOD sadržajem.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/narudzba"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-gradient-to-r from-blue-600 to-purple-600 text-white font-bold rounded-xl shadow-lg shadow-blue-600/25 hover:shadow-xl hover:-translate-y-0.5 transition-all duration-200"
          >
            🎁 Testiraj besplatno 24h
          </a>
          <a
            href="https://wa.me/4915251741280"
            target="_blank" rel="noopener"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-stone-800 border border-stone-600 text-gray-300 font-semibold rounded-xl hover:bg-stone-700 hover:text-white transition-all duration-200"
          >
            <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Pitajte na WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
