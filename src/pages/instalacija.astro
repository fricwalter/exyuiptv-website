---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Instalacija - EXYU IPTV" description="Jednostavan vodič za instalaciju IPTV-a na svim uređajima - Smart TV, Android box, Fire TV, mobitel i računar.">
  <section class="section bg-white">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-4xl md:text-5xl font-bold text-slate-800 mb-4">
          Vodič za instalaciju
        </h1>
        <p class="text-xl text-slate-600 mb-12">
          Jednostavne upute za instalaciju IPTV-a na vašem uređaju
        </p>

        <!-- Devices -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 mb-12">
          <div class="bg-blue-50 rounded-xl p-6 text-center">
            <div class="text-4xl mb-3">📺</div>
            <h3 class="font-semibold text-slate-800">Smart TV</h3>
          </div>
          <div class="bg-slate-50 rounded-xl p-6 text-center">
            <div class="text-4xl mb-3">📱</div>
            <h3 class="font-semibold text-slate-800">Android</h3>
          </div>
          <div class="bg-slate-50 rounded-xl p-6 text-center">
            <div class="text-4xl mb-3">🔥</div>
            <h3 class="font-semibold text-slate-800">Fire TV</h3>
          </div>
          <div class="bg-slate-50 rounded-xl p-6 text-center">
            <div class="text-4xl mb-3">💻</div>
            <h3 class="font-semibold text-slate-800">PC / Mac</h3>
          </div>
        </div>

        <!-- Android Box / Firestick -->
        <div class="card mb-8">
          <h2 class="text-2xl font-bold text-slate-800 mb-6">Instalacija na Android box / Fire TV Stick</h2>
          <ol class="space-y-4">
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-8 h-8 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold">1</span>
              <div>
                <h4 class="font-semibold text-slate-800">Preuzmite aplikaciju</h4>
                <p class="text-slate-600">Preuzmite IPTV aplikaciju (npr. IPTV Smarters, GSE Smart IPTV ili Smart STB) iz Google Play Storea ili Amazon Appstorea.</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-8 h-8 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold">2</span>
              <div>
                <h4 class="font-semibold text-slate-800">Unesite podatke za prijavu</h4>
                <p class="text-slate-600">Nakon instalacije, pokrenite aplikaciju i unesite podatke koje ste dobili nakon narudžbe (URL i kod).</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-8 h-8 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold">3</span>
              <div>
                <h4 class="font-semibold text-slate-800">Uživajte u gledanju</h4>
                <p class="text-slate-600">Nakon uspješne prijave, moći ćete pristupiti svim kanalima i sadržaju.</p>
              </div>
            </li>
          </ol>
        </div>

        <!-- Smart TV -->
        <div class="card mb-8">
          <h2 class="text-2xl font-bold text-slate-800 mb-6">Instalacija na Smart TV (Samsung/LG)</h2>
          <ol class="space-y-4">
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-8 h-8 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold">1</span>
              <div>
                <h4 class="font-semibold text-slate-800">Otvorite Smart Hub / LG Content Store</h4>
                <p class="text-slate-600">Na vašem Smart TV-u pristupite trgovini aplikacijama.</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-8 h-8 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold">2</span>
              <div>
                <h4 class="font-semibold text-slate-800">Pretražite i instalirajte IPTV aplikaciju</h4>
                <p class="text-slate-600">Pretražite "IPTV" ili "Smart IPTV" i instalirajte odgovarajuću aplikaciju za vaš TV.</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-8 h-8 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold">3</span>
              <div>
                <h4 class="font-semibold text-slate-800">Unesite podatke</h4>
                <p class="text-slate-600">Pokrenite aplikaciju i unesite MAC adresu uređaja i podatke za prijavu koje ste dobili od nas.</p>
              </div>
            </li>
          </ol>
        </div>

        <!-- Mobile -->
        <div class="card mb-8">
          <h2 class="text-2xl font-bold text-slate-800 mb-6">Instalacija na mobilni telefon / tablet</h2>
          <ol class="space-y-4">
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-8 h-8 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold">1</span>
              <div>
                <h4 class="font-semibold text-slate-800">Preuzmite aplikaciju</h4>
                <p class="text-slate-600">Preuzmite IPTV aplikaciju iz App Storea (iOS) ili Google Play Storea (Android).</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-8 h-8 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold">2</span>
              <div>
                <h4 class="font-semibold text-slate-800">Kreirajte listu kanala</h4>
                <p class="text-slate-600">U aplikaciji dodajte novu listu kanala koristeći našu Xtream Codes ili M3U linku.</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-8 h-8 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold">3</span>
              <div>
                <h4 class="font-semibold text-slate-800">Gledajte uživo</h4>
                <p class="text-slate-600">Odaberite kanal i uživajte u gledanju na vašem mobilnom uređaju bilo gdje.</p>
              </div>
            </li>
          </ol>
        </div>

        <!-- PC -->
        <div class="card">
          <h2 class="text-2xl font-bold text-slate-800 mb-6">Instalacija na računar (PC / Mac)</h2>
          <ol class="space-y-4">
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-8 h-8 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold">1</span>
              <div>
                <h4 class="font-semibold text-slate-800">Preuzmite VLC Player</h4>
                <p class="text-slate-600">Besplatni VLC media player možete preuzeti sa videoLAN.org.</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-8 h-8 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold">2</span>
              <div>
                <h4 class="font-semibold text-slate-800">Otvorite M3U listu</h4>
                <p class="text-slate-600">U VLC playeru idite na Media > Open Network Stream i zalijepite našu M3U linku.</p>
              </div>
            </li>
            <li class="flex gap-4">
              <span class="flex-shrink-0 w-8 h-8 bg-blue-600 text-white rounded-full flex items-center justify-center font-bold">3</span>
              <div>
                <h4 class="font-semibold text-slate-800">Uživajte</h4>
                <p class="text-slate-600">Kliknite Play i gledajte svoje omiljene kanale na računaru.</p>
              </div>
            </li>
          </ol>
        </div>

        <div class="mt-12 bg-blue-50 rounded-2xl p-8 text-center">
          <h3 class="text-xl font-bold text-slate-800 mb-4">Trebate pomoć?</h3>
          <p class="text-slate-600 mb-6">
            Naš tim je dostupan 24/7 za tehničku pomoć pri instalaciji.
          </p>
          <a href="/narudzba" class="btn btn-primary">
            Kontaktirajte podršku
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
