---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Kontakt - EXYU IPTV" description="Kontaktirajte EXYU IPTV tim - dostupni 24/7 za sva pitanja i tehničku podršku.">
  <section class="section bg-white">
    <div class="container-custom">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-4xl md:text-5xl font-bold text-slate-800 mb-4">
          Kontakt
        </h1>
        <p class="text-xl text-slate-600 mb-12">
          Javite nam se - uvijek smo dostupni za vas
        </p>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
          <!-- Contact Info -->
          <div>
            <div class="card mb-8">
              <h2 class="text-2xl font-bold text-slate-800 mb-6">Kontakt informacije</h2>
              <ul class="space-y-6">
                <li class="flex items-start gap-4">
                  <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center flex-shrink-0">
                    <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                    </svg>
                  </div>
                  <div>
                    <h3 class="font-semibold text-slate-800">Telefon</h3>
                    <a href="tel:+4915251741280" class="text-blue-600 hover:text-blue-700 text-lg">+49 152 51741280</a>
                    <p class="text-slate-500 text-sm">Dostupni 24/7</p>
                  </div>
                </li>
                <li class="flex items-start gap-4">
                  <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center flex-shrink-0">
                    <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                    </svg>
                  </div>
                  <div>
                    <h3 class="font-semibold text-slate-800">E-mail</h3>
                    <a href="mailto:info@exyuiptv.org" class="text-blue-600 hover:text-blue-700">info@exyuiptv.org</a>
                  </div>
                </li>
                <li class="flex items-start gap-4">
                  <div class="w-12 h-12 bg-blue-100 rounded-xl flex items-center justify-center flex-shrink-0">
                    <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                  </div>
                  <div>
                    <h3 class="font-semibold text-slate-800">Radno vrijeme</h3>
                    <p class="text-slate-600">Podrška 24/7 - uvijek smo dostupni</p>
                  </div>
                </li>
              </ul>
            </div>

            <div class="card">
              <h2 class="text-2xl font-bold text-slate-800 mb-6">Pratite nas</h2>
              <div class="flex gap-4">
                <a href="https://www.facebook.com/FluidVisionTV" target="_blank" rel="noopener" class="w-12 h-12 bg-blue-600 text-white rounded-xl flex items-center justify-center hover:bg-blue-700 transition-colors">
                  <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </a>
                <a href="https://wa.me/4915251741280" target="_blank" rel="noopener" class="w-12 h-12 bg-green-500 text-white rounded-xl flex items-center justify-center hover:bg-green-600 transition-colors">
                  <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                </a>
              </div>
            </div>
          </div>

          <!-- Contact Form -->
          <div class="card">
            <h2 class="text-2xl font-bold text-slate-800 mb-6">Pošaljite poruku</h2>
            <form class="space-y-6">
              <div>
                <label for="name" class="label">Ime i prezime</label>
                <input type="text" id="name" name="name" class="input" placeholder="Vaše ime" required />
              </div>
              <div>
                <label for="email" class="label">E-mail adresa</label>
                <input type="email" id="email" name="email" class="input" placeholder="vaš@email.com" required />
              </div>
              <div>
                <label for="phone" class="label">Telefon (opcionalno)</label>
                <input type="tel" id="phone" name="phone" class="input" placeholder="+387 61 123 456" />
              </div>
              <div>
                <label for="subject" class="label">Tema</label>
                <select id="subject" name="subject" class="input">
                  <option value="general">Opće pitanje</option>
                  <option value="order">Narudžba</option>
                  <option value="support">Tehnička podrška</option>
                  <option value="billing">Plaćanje i fakturiranje</option>
                </select>
              </div>
              <div>
                <label for="message" class="label">Poruka</label>
                <textarea id="message" name="message" rows="5" class="input" placeholder="Vaša poruka..." required></textarea>
              </div>
              <button type="submit" class="btn btn-primary w-full">
                Pošalji poruku
                <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                </svg>
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
