---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Kontakt - EXYU IPTV" description="Kontaktirajte EXYU IPTV tim - dostupni 24/7 za sva pitanja i tehničku podršku.">

  <!-- Hero -->
  <section class="relative pt-32 pb-20 overflow-hidden" style="background: linear-gradient(135deg, #1e3a5f 0%, #1c1917 60%);">
    <div class="absolute inset-0 opacity-10"
      style="background-image: radial-gradient(circle at 20% 50%, #3b82f6 0%, transparent 50%), radial-gradient(circle at 80% 20%, #7c3aed 0%, transparent 50%);">
    </div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <div class="text-6xl mb-6">📞</div>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white mb-6">
        Kontaktirajte <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-purple-400">Nas</span>
      </h1>
      <p class="text-xl text-gray-300 max-w-2xl mx-auto">
        Naš tim je dostupan 24/7 — odgovaramo brzo na sva pitanja i zahtjeve
      </p>
    </div>
  </section>

  <!-- Main Content -->
  <section class="py-20 bg-stone-900">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

        <!-- Left: Contact Info -->
        <div class="space-y-6">

          <!-- Info Cards -->
          <div class="bg-stone-800 border border-stone-700 rounded-2xl p-8">
            <h2 class="text-2xl font-bold text-white mb-8">Kontakt informacije</h2>
            <ul class="space-y-8">
              <li class="flex items-start gap-4">
                <div class="w-12 h-12 bg-blue-600/20 border border-blue-500/30 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-gray-300 text-sm uppercase tracking-wide mb-1">Telefon</h3>
                  <a href="tel:+4915251741280" class="text-white text-xl font-bold hover:text-blue-400 transition-colors">+49 152 51741280</a>
                  <p class="text-gray-500 text-sm mt-1">Dostupni 24/7</p>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <div class="w-12 h-12 bg-purple-600/20 border border-purple-500/30 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-gray-300 text-sm uppercase tracking-wide mb-1">E-mail</h3>
                  <a href="mailto:info@exyuiptv.org" class="text-white text-xl font-bold hover:text-purple-400 transition-colors">info@exyuiptv.org</a>
                </div>
              </li>
              <li class="flex items-start gap-4">
                <div class="w-12 h-12 bg-green-600/20 border border-green-500/30 rounded-xl flex items-center justify-center flex-shrink-0">
                  <svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                  </svg>
                </div>
                <div>
                  <h3 class="font-semibold text-gray-300 text-sm uppercase tracking-wide mb-1">Radno vrijeme</h3>
                  <p class="text-white text-lg font-semibold">Podrška 24/7</p>
                  <p class="text-gray-500 text-sm mt-1">Uvijek smo dostupni za vas</p>
                </div>
              </li>
            </ul>
          </div>

          <!-- Social / Quick Contact -->
          <div class="bg-stone-800 border border-stone-700 rounded-2xl p-8">
            <h2 class="text-2xl font-bold text-white mb-6">Brzi kontakt</h2>
            <div class="flex gap-4">
              <a href="https://www.facebook.com/FluidVisionTV" target="_blank" rel="noopener"
                class="flex-1 flex items-center justify-center gap-3 py-4 bg-blue-600/20 border border-blue-500/30 text-blue-400 rounded-xl hover:bg-blue-600/30 transition-colors font-semibold">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
                Facebook
              </a>
              <a href="https://wa.me/4915251741280" target="_blank" rel="noopener"
                class="flex-1 flex items-center justify-center gap-3 py-4 bg-green-600/20 border border-green-500/30 text-green-400 rounded-xl hover:bg-green-600/30 transition-colors font-semibold">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                WhatsApp
              </a>
            </div>
          </div>
        </div>

        <!-- Right: Contact Form -->
        <div class="bg-stone-800 border border-stone-700 rounded-2xl p-8">
          <h2 class="text-2xl font-bold text-white mb-8">Pošaljite poruku</h2>
          <form class="space-y-6">
            <div>
              <label for="name" class="block text-sm font-semibold text-gray-300 uppercase tracking-wide mb-2">Ime i prezime</label>
              <input
                type="text" id="name" name="name"
                placeholder="Vaše ime"
                required
                class="w-full bg-stone-900 border border-stone-600 text-white placeholder-gray-500 rounded-xl px-4 py-3 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition-colors"
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-semibold text-gray-300 uppercase tracking-wide mb-2">E-mail adresa</label>
              <input
                type="email" id="email" name="email"
                placeholder="vaš@email.com"
                required
                class="w-full bg-stone-900 border border-stone-600 text-white placeholder-gray-500 rounded-xl px-4 py-3 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition-colors"
              />
            </div>
            <div>
              <label for="phone" class="block text-sm font-semibold text-gray-300 uppercase tracking-wide mb-2">Telefon <span class="text-gray-500 normal-case font-normal">(opcionalno)</span></label>
              <input
                type="tel" id="phone" name="phone"
                placeholder="+387 61 123 456"
                class="w-full bg-stone-900 border border-stone-600 text-white placeholder-gray-500 rounded-xl px-4 py-3 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition-colors"
              />
            </div>
            <div>
              <label for="subject" class="block text-sm font-semibold text-gray-300 uppercase tracking-wide mb-2">Tema</label>
              <select
                id="subject" name="subject"
                class="w-full bg-stone-900 border border-stone-600 text-white rounded-xl px-4 py-3 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition-colors"
              >
                <option value="general">Opće pitanje</option>
                <option value="order">Narudžba</option>
                <option value="support">Tehnička podrška</option>
                <option value="billing">Plaćanje i fakturiranje</option>
              </select>
            </div>
            <div>
              <label for="message" class="block text-sm font-semibold text-gray-300 uppercase tracking-wide mb-2">Poruka</label>
              <textarea
                id="message" name="message"
                rows="5"
                placeholder="Vaša poruka..."
                required
                class="w-full bg-stone-900 border border-stone-600 text-white placeholder-gray-500 rounded-xl px-4 py-3 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition-colors resize-none"
              ></textarea>
            </div>
            <button
              type="submit"
              class="w-full inline-flex items-center justify-center gap-2 px-8 py-4 bg-gradient-to-r from-blue-600 to-purple-600 text-white font-bold rounded-xl shadow-lg hover:shadow-blue-500/25 hover:-translate-y-0.5 transition-all"
            >
              Pošalji poruku
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </button>
          </form>
        </div>

      </div>
    </div>
  </section>

</BaseLayout>
