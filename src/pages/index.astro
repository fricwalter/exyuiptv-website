---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import CategoryTabs from '../components/CategoryTabs.tsx';
import Devices from '../components/Devices.astro';
import Pricing from '../components/Pricing.tsx';
import FAQ from '../components/FAQ.tsx';
---

<BaseLayout
  title="EXYU IPTV | Premium Balkanska TV za Dijasporu - 25.000+ Kanala u 4K"
  description="#1 IPTV za dijasporu. Gledaj EXYU kanale bez ugovora i bez zamrzavanja, uz 25.000+ kanala i videoteku u 4K rezoluciji. Savršeno za Njemačku, Austriju i Švicarsku."
>
  <h1 class="sr-only">EXYU IPTV kanali za dijasporu</h1>
  <Hero />
  <Features />
  <CategoryTabs client:visible />
  <Devices />
  <Pricing client:visible />
  <FAQ client:visible />

  <!-- Blog / Country Links CTA Section -->
  <section class="py-20 bg-stone-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
          IPTV <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-purple-400">Dostupan Širom Dijaspore</span>
        </h2>
        <p class="text-lg text-gray-300">Gledajte balkansku televiziju bilo gdje u svijetu</p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
        {[
          { name: "Njemačka", flag: "🇩🇪", href: "/exyu-iptv-deutschland" },
          { name: "Austrija", flag: "🇦🇹", href: "/exyuiptv-austrija" },
          { name: "Švicarska", flag: "🇨🇭", href: "/exyuiptv-svicarska" },
          { name: "Hrvatska", flag: "🇭🇷", href: "/exyuiptv-hrvatska" },
          { name: "Bosna", flag: "🇧🇦", href: "/exyuiptv-bosna" },
          { name: "Srbija", flag: "🇷🇸", href: "/exyuiptv-srbija" },
        ].map((country) => (
          <a
            href={country.href}
            class="group bg-stone-900 hover:bg-stone-700 border border-stone-700 hover:border-blue-500 rounded-2xl text-center py-6 px-4 transition-all duration-300 hover:-translate-y-1"
          >
            <div class="text-4xl mb-2">{country.flag}</div>
            <div class="font-semibold text-gray-200 group-hover:text-blue-400 transition-colors text-sm">
              {country.name}
            </div>
          </a>
        ))}
      </div>

      <div class="text-center mt-10">
        <a
          href="/exyuiptv-bosna"
          class="inline-flex items-center gap-2 px-6 py-3 border-2 border-stone-600 hover:border-blue-500 text-gray-300 hover:text-white font-semibold rounded-xl transition-all duration-200"
        >
          Pogledaj sve države →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
