---
const navLinks = [
  { href: '/', label: 'Početna' },
  { href: '/o-nama', label: 'O nama' },
  { href: '/tv-lista-kanala', label: 'Lista kanala' },
  { href: '/instalacija', label: 'Instalacija' },
  { href: '/blog', label: 'Blog' },
  { href: '/kontakt', label: 'Kontakt' },
  { href: '/osnovni-paket', label: 'Cijene', primary: true },
];

const countryLinks = [
  { href: '/exyu-iptv-deutschland', label: 'Njemačka' },
  { href: '/exyuiptv-austrija', label: 'Austrija' },
  { href: '/exyuiptv-svicarska', label: 'Švicarska' },
  { href: '/exyuiptv-hrvatska', label: 'Hrvatska' },
  { href: '/exyuiptv-bosna', label: 'Bosna i Hercegovina' },
  { href: '/exyuiptv-srbija', label: 'Srbija' },
  { href: '/exyuiptv-slovenija', label: 'Slovenija' },
  { href: '/exyuiptv-crna-gora', label: 'Crna Gora' },
  { href: '/exyuiptv-makedonija', label: 'Makedonija' },
  { href: '/exyuiptv-usa', label: 'SAD' },
  { href: '/exyuiptv-velika-britanija', label: 'Velika Britanija' },
  { href: '/exyuiptv-australija', label: 'Australija' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-md shadow-sm">
  <div class="container-custom">
    <!-- Main Navigation -->
    <nav class="flex items-center justify-between h-16 md:h-20">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3">
        <div class="w-10 h-10 bg-gradient-to-br from-blue-600 to-blue-800 rounded-lg flex items-center justify-center">
          <span class="text-white font-bold text-lg">EX</span>
        </div>
        <span class="text-xl font-bold text-slate-800">EXYU<span class="text-blue-600">IPTV</span></span>
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center gap-1">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class:list={[
              "px-4 py-2 rounded-lg font-medium transition-all duration-200",
              link.primary
                ? "bg-blue-600 text-white hover:bg-blue-700"
                : "text-slate-600 hover:text-blue-600 hover:bg-blue-50"
            ]}
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 rounded-lg hover:bg-slate-100"
        aria-label="Otvorite meni"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </nav>

    <!-- Country Links Bar -->
    <div class="hidden lg:flex items-center gap-2 py-3 border-t border-slate-100 overflow-x-auto">
      <span class="text-sm text-slate-500 mr-2">IPTV po državama:</span>
      {countryLinks.map((link) => (
        <a
          href={link.href}
          class="text-sm text-slate-600 hover:text-blue-600 whitespace-nowrap transition-colors"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden lg:hidden bg-white border-t border-slate-100">
    <div class="container-custom py-4 space-y-2">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            "block px-4 py-3 rounded-lg font-medium transition-all",
            link.primary
              ? "bg-blue-600 text-white text-center"
              : "text-slate-600 hover:bg-blue-50"
          ]}
        >
          {link.label}
        </a>
      ))}
      <div class="pt-4 border-t border-slate-100">
        <p class="text-sm text-slate-500 mb-2">IPTV po državama:</p>
        <div class="grid grid-cols-2 gap-2">
          {countryLinks.map((link) => (
            <a
              href={link.href}
              class="px-3 py-2 text-sm text-slate-600 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors"
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</header>

<div class="h-28 md:h-32"></div>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
