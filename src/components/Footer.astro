---
const footerLinks = [
  {
    title: 'Sve Stranice',
    links: [
      { name: 'Početna', href: '/' },
      { name: 'Blog', href: '/blog' },
      { name: 'TV Lista Kanala', href: '/tv-lista-kanala' },
      { name: 'Instalacija', href: '/instalacija' },
      { name: 'Kontakt', href: '/kontakt' },
      { name: 'O Nama', href: '/o-nama' },
    ]
  },
  {
    title: 'Pravne Informacije',
    links: [
      { name: 'Uslovi Korištenja', href: '/uslovi-koristenja' },
      { name: 'Politika Privatnosti', href: '/politika-privatnosti' },
      { name: 'Povrat Novca', href: '/politika-povrata-novca' },
      { name: 'Politika Kolačića', href: '/politika-kolacica' },
    ]
  }
];

const countryLinks = [
  { name: 'Njemačka', flag: '🇩🇪', href: '/exyu-iptv-deutschland' },
  { name: 'Austrija', flag: '🇦🇹', href: '/exyuiptv-austrija' },
  { name: 'Švicarska', flag: '🇨🇭', href: '/exyuiptv-svicarska' },
  { name: 'Bosna', flag: '🇧🇦', href: '/exyuiptv-bosna' },
  { name: 'Hrvatska', flag: '🇭🇷', href: '/exyuiptv-hrvatska' },
  { name: 'Srbija', flag: '🇷🇸', href: '/exyuiptv-srbija' },
  { name: 'USA', flag: '🇺🇸', href: '/exyuiptv-usa' },
  { name: 'Velika Britanija', flag: '🇬🇧', href: '/exyuiptv-velika-britanija' },
  { name: 'Australija', flag: '🇦🇺', href: '/exyuiptv-australija' },
  { name: 'Belgija', flag: '🇧🇪', href: '/exyuiptv-belgija' },
  { name: 'Makedonija', flag: '🇲🇰', href: '/exyuiptv-makedonija' },
  { name: 'Slovenija', flag: '🇸🇮', href: '/exyuiptv-slovenija' },
  { name: 'Crna Gora', flag: '🇲🇪', href: '/exyuiptv-crna-gora' },
  { name: 'Španija', flag: '🇪🇸', href: '/exyuiptv-spanija' },
  { name: 'Švedska', flag: '🇸🇪', href: '/exyuiptv-svedska' },
];

const whatsappNumber = '+4915251741280';
const email = 'info@exyuiptv.org';
---

<footer class="bg-gray-900 text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-12">
      <!-- Brand -->
      <div class="lg:col-span-2">
        <a href="/" class="flex items-center gap-2 mb-6">
          <div class="w-12 h-12 bg-gradient-to-br from-blue-600 to-purple-600 rounded-xl flex items-center justify-center shadow-lg">
            <span class="text-white font-bold text-xl">EX</span>
          </div>
          <span class="text-2xl font-bold">
            <span class="text-blue-400">EXYU</span> IPTV
          </span>
        </a>
        <p class="text-gray-400 mb-6 max-w-md">
          Najbolja internet televizija za dijasporu. Gledajte omiljene kanale bilo gdje u svijetu bez ugovora i bez zamrzavanja u 4K rezoluciji.
        </p>

        <div class="space-y-3">
          <div class="flex items-center gap-3">
            <span class="w-10 h-10 bg-green-500/20 rounded-lg flex items-center justify-center text-lg">💬</span>
            <span class="text-gray-300">
              WhatsApp:
              <a
                href={`https://wa.me/${whatsappNumber.replace(/\D/g, '')}`}
                class="text-green-400 hover:underline ml-1"
              >
                {whatsappNumber}
              </a>
            </span>
          </div>
          <div class="flex items-center gap-3">
            <span class="w-10 h-10 bg-blue-500/20 rounded-lg flex items-center justify-center text-lg">✉️</span>
            <span class="text-gray-300">
              Email:
              <a href={`mailto:${email}`} class="text-blue-400 hover:underline ml-1">{email}</a>
            </span>
          </div>
          <div class="flex items-center gap-3">
            <span class="w-10 h-10 bg-purple-500/20 rounded-lg flex items-center justify-center text-lg">🕐</span>
            <span class="text-gray-300">Radno vrijeme: 09:00 - 22:00</span>
          </div>
        </div>
      </div>

      <!-- Links -->
      {footerLinks.map((section) => (
        <div>
          <h3 class="text-lg font-semibold mb-4">{section.title}</h3>
          <ul class="space-y-3">
            {section.links.map((link) => (
              <li>
                <a href={link.href} class="text-gray-400 hover:text-white transition-colors">
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- IPTV po Državama -->
    <div class="mt-12 pt-10 border-t border-gray-800">
      <h3 class="text-lg font-semibold mb-6 text-white">
        📺 IPTV po Državama
      </h3>
      <div class="grid grid-cols-3 sm:grid-cols-5 lg:grid-cols-8 gap-3">
        {countryLinks.map((country) => (
          <a
            href={country.href}
            class="flex flex-col items-center gap-1 p-3 rounded-xl border border-gray-800 hover:border-blue-500 hover:bg-gray-800 transition-all duration-200 text-center group"
          >
            <span class="text-2xl">{country.flag}</span>
            <span class="text-xs text-gray-400 group-hover:text-blue-400 transition-colors font-medium leading-tight">{country.name}</span>
          </a>
        ))}
      </div>
    </div>

    <div class="mt-10 pt-8 border-t border-gray-800">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-gray-400 text-sm">
          © {new Date().getFullYear()} EXYU IPTV. Sva prava zadržana.
        </p>
        <div class="flex flex-wrap gap-6">
          <a href="/uslovi-koristenja" class="text-gray-400 hover:text-white text-sm transition-colors">Uslovi korištenja</a>
          <a href="/politika-privatnosti" class="text-gray-400 hover:text-white text-sm transition-colors">Privatnost</a>
          <a href="/politika-povrata-novca" class="text-gray-400 hover:text-white text-sm transition-colors">Povrat novca</a>
          <a href="/kontakt" class="text-gray-400 hover:text-white text-sm transition-colors">Kontakt</a>
        </div>
      </div>
    </div>
  </div>
</footer>

<!-- WhatsApp Floating Button -->
<a
  href={`https://wa.me/${whatsappNumber.replace(/\D/g, '')}`}
  class="fixed bottom-6 right-6 z-50 w-14 h-14 bg-green-500 rounded-full shadow-lg flex items-center justify-center hover:bg-green-600 hover:scale-110 transition-all duration-200"
  aria-label="Kontaktirajte nas na WhatsAppu"
  target="_blank"
  rel="noopener noreferrer"
>
  <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
  </svg>
</a>
